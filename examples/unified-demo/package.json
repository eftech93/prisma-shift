{
  "name": "unified-demo",
  "version": "1.0.0",
  "description": "Unified demo showing all migration scenarios",
  "scripts": {
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset --force",
    "data:migrate": "prisma-shift run",
    "data:status": "prisma-shift status",
    "data:create": "prisma-shift create",
    "data:reset": "prisma-shift reset",
    "data:squash": "prisma-shift squash",
    "deploy": "./deploy.sh",
    "dev": "ts-node src/app.ts",
    "studio": "prisma studio",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f",
    "start": "npm run infra:up && npm run migrate",
    "start:fresh": "docker-compose down -v && npm run infra:up && npm run migrate",
    "migrate": "npm run wait:db && npx prisma-shift deploy",
    "reset": "npm run data:reset && npm run migrate",
    "wait:db": "node wait-for-db.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "prisma-shift": "file:../.."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}

# Database connection string
# For Docker Compose setup (default):
DATABASE_URL="postgresql://bloguser:blogpass@localhost:5432/blog_demo?schema=public"

# Alternative: Using Docker Compose service name (when running in container):
# DATABASE_URL="postgresql://bloguser:blogpass@postgres:5432/blog_demo?schema=public"

# Optional: Data migrations configuration
DATA_MIGRATIONS_DIR="./prisma/data-migrations"
DATA_MIGRATIONS_TABLE="_dataMigration"
